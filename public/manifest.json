{
  "manifest_version": 3,
  "name": "Explain This – Instant AI Explanations",
  "version": "1.1.4",
  "description": "Understand highlighted text instantly without leaving the page.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Explain highlighted text"
  },

  "options_page": "settings.html",

  "background": {
    "service_worker": "background.js"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "windows"
  ],

  "host_permissions": [
    "https://explain-this-api.explainthis-hc907.workers.dev/*"
  ],

  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "commands": {
    "explain-selection": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Explain highlighted text"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icon32.png"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
